---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/TopNav.astro'
import Pricing from '../components/Pricing.astro'
import Footer from '../components/Footer.astro'
import en from '../i18n/en'
import { getAppHref, getCtaHref } from '../lib/app-url'
import { pricingStructuredData } from '../lib/structured-data'

const t = en
const ctaHref = getCtaHref()
const checkoutHref = getAppHref('/billing/checkout?plan=pro&interval=monthly')
const pathname = '/pricing'
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={t.pricing.meta.title}
  description={t.pricing.meta.description}
  ogImage={t.pricing.meta.ogImage}
  structuredData={pricingStructuredData(t, 'en', pathname)}
>
  <TopNav t={t.nav} ctaHref={ctaHref} />
  <main>
    <Pricing t={t.pricing} appHref={ctaHref} checkoutHref={checkoutHref} />
  </main>
  <Footer t={t.footer} enHref="/pricing" zhHref="/zh-CN/pricing" currentLocale="en" />
</BaseLayout>
