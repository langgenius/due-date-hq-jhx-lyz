---
import type { ProblemCopy } from '../i18n/types'
import SectionEyebrow from './primitives/SectionEyebrow.astro'

interface Props {
  t: ProblemCopy
}

const { t } = Astro.props

const severityPillClass: Record<'critical' | 'high' | 'medium', string> = {
  critical: 'bg-severity-critical-tint text-severity-critical',
  high: 'bg-severity-high-tint text-severity-high',
  medium: 'bg-severity-medium-tint text-severity-medium',
}
---

<section class="border-b border-border-default bg-bg-canvas">
  <div class="mx-auto max-w-[1440px] px-20 py-20">
    <!-- Section header -->
    <div class="grid grid-cols-12 gap-12">
      <div class="col-span-12 lg:col-span-7">
        <SectionEyebrow index={t.index} label={t.eyebrow} />
        <h2 class="mt-6 max-w-[640px] text-display-large font-semibold tracking-tight text-text-primary">
          {t.title}
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-5">
        <p class="text-[15px] leading-relaxed text-text-secondary">{t.paragraph}</p>
        <p class="mt-6 font-mono text-[12px] text-text-muted">{t.footnote}</p>
      </div>
    </div>

    <!-- Cards grid -->
    <div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-3">
      {t.cards.map((card) => (
        <article class="rounded-xl border border-border-default bg-bg-elevated p-4">
          <div class="flex items-center justify-between">
            <span class={`inline-flex items-center rounded-md px-2 py-1 font-mono text-2xs font-semibold tracking-[0.16em] ${severityPillClass[card.severity]}`}>
              {card.tag}
            </span>
            <span class="font-mono text-[12px] text-text-muted">{card.cadence}</span>
          </div>
          <h3 class="mt-7 text-[20px] font-semibold leading-snug text-text-primary">{card.headline}</h3>
          <p class="mt-6 text-[13px] leading-relaxed text-text-secondary">{card.body}</p>
          <div class="mt-8 rounded-lg border border-border-subtle bg-bg-canvas">
            <div class="flex items-center justify-between border-b border-border-subtle px-3 py-2 text-[13px]">
              <span class="font-medium text-text-primary">{card.listTitle}</span>
              <span class="font-mono text-[12px] text-text-muted">{card.listSummary}</span>
            </div>
            {card.rows.map((row) => (
              <div class="flex items-center gap-3 border-b border-border-subtle px-3 py-2 text-[13px] last:border-b-0">
                <span class="block h-1.5 w-1.5 shrink-0 rounded-full bg-accent-default"></span>
                <span class="font-mono text-[12px] text-text-secondary">{row.pill}</span>
                <span class="flex-1 truncate text-text-secondary">{row.text}</span>
                <span class="font-mono text-[12px] text-text-muted">{row.date}</span>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
