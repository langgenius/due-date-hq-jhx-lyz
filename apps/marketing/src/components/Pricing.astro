---
import type { PricingCopy, PricingPlanCopy } from '../i18n/types'

interface Props {
  t: PricingCopy
  appHref: string
  checkoutHref: string
}

const { t, appHref, checkoutHref } = Astro.props

function hrefFor(plan: PricingPlanCopy): string {
  if (plan.hrefKind === 'checkout') return checkoutHref
  if (plan.hrefKind === 'app') return appHref
  return 'mailto:sales@duedatehq.com?subject=DueDateHQ%20Firm'
}
---

<section class="bg-bg-canvas">
  <div class="mx-auto max-w-[1440px] px-20 py-20">
    <!-- Hero — Figma: pad 80/80/56/80, gap 20 -->
    <div>
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {t.hero.eyebrow}
      </span>
      <h1
        class="mt-5 max-w-[840px] text-display-large font-semibold leading-[1.1] tracking-tight text-text-primary"
      >
        {t.hero.title}
      </h1>
      <p class="mt-5 max-w-[760px] text-[17px] leading-[1.6] text-text-secondary">
        {t.hero.description}
      </p>
      <p class="mt-5 font-mono text-[11px] text-text-muted">{t.hero.note}</p>
    </div>

    <!-- Plans — Figma: pad 0/80/56/80 -->
    <section class="mt-14">
      <header class="flex flex-wrap items-end justify-between gap-4 pt-2 pb-6">
        <div class="flex flex-col gap-1.5">
          <span
            class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent"
          >
            {t.plansHeader.eyebrow}
          </span>
          <h2
            class="text-[22px] font-semibold leading-[1.3] tracking-tight text-text-primary"
          >
            {t.plansHeader.title}
          </h2>
        </div>
        <span
          class="font-mono text-[11px] font-medium tracking-[0.13em] text-text-secondary"
        >
          {t.plansHeader.note}
        </span>
      </header>

      <div class="grid items-stretch gap-4 lg:grid-cols-3">
        {
          t.plans.map((plan) => {
            const isRecommended = Boolean(plan.badge)
            return (
              <article
                class:list={[
                  'flex flex-col rounded-xl bg-bg-panel p-8',
                  isRecommended
                    ? 'border-[1.5px] border-accent-default bg-bg-elevated'
                    : 'border border-border-default',
                ]}
              >
                <div class="flex flex-1 flex-col gap-7">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="text-[18px] font-semibold leading-[1.4] tracking-tight text-text-primary">
                      {plan.name}
                    </h3>
                    {plan.badge ? (
                      <span class="rounded-sm bg-accent-tint px-2 py-1 text-[11px] font-medium tracking-[0.04em] text-text-accent">
                        {plan.badge}
                      </span>
                    ) : null}
                  </div>

                  <p class="text-[13px] leading-[1.6] text-text-secondary">
                    {plan.description}
                  </p>

                  <div class="flex flex-col gap-1.5 pt-1">
                    <div class="flex items-baseline gap-2">
                      <span
                        class:list={[
                          'text-[40px] font-semibold leading-none tracking-tight text-text-primary',
                          plan.priceKind === 'text' ? 'font-sans' : 'font-mono font-bold',
                        ]}
                      >
                        {plan.price}
                      </span>
                      <span class="text-[13px] leading-[1.4] text-text-secondary">
                        {plan.cadence}
                      </span>
                    </div>
                    <p class="font-mono text-[11px] font-medium tracking-[0.06em] text-text-muted">
                      {plan.seats}
                    </p>
                  </div>

                  <div class="h-px w-full bg-border-subtle" aria-hidden="true" />

                  <ul class="flex flex-col gap-3 text-[13px] leading-[1.5] text-text-primary">
                    {plan.features.map((feature) => (
                      <li class="flex items-center gap-2.5">
                        <span
                          aria-hidden="true"
                          class="grid size-4 shrink-0 place-items-center rounded-sm bg-accent-tint text-[10px] font-semibold leading-none text-text-accent"
                        >
                          ✓
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <a
                  href={hrefFor(plan)}
                  class:list={[
                    'mt-10 inline-flex h-11 items-center justify-center gap-1.5 rounded-md px-3.5 text-[13px] font-medium transition-colors',
                    isRecommended
                      ? 'bg-accent-default text-primary-foreground hover:bg-accent-hover'
                      : 'border border-border-strong bg-bg-elevated text-text-primary hover:border-text-muted hover:bg-bg-canvas',
                  ]}
                  data-event={`marketing.pricing.${plan.hrefKind}`}
                >
                  <span>{plan.cta}</span>
                  {isRecommended ? <span aria-hidden="true">→</span> : null}
                </a>
              </article>
            )
          })
        }
      </div>
    </section>

    <!-- FAQ — Figma: pad 24/80/96/80, gap 32 -->
    <section class="mt-6 pt-6 pb-12">
      <header class="mb-8 flex flex-col gap-2">
        <span
          class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent"
        >
          {t.faqHeader.eyebrow}
        </span>
        <h2
          class="text-[24px] font-semibold leading-[1.3] tracking-tight text-text-primary"
        >
          {t.faqHeader.title}
        </h2>
      </header>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          t.faq.map((item) => (
            <section class="flex flex-col gap-3 rounded-xl border border-border-default bg-bg-panel p-6">
              <h3 class="text-[15px] font-semibold leading-[1.4] tracking-tight text-text-primary">
                {item.question}
              </h3>
              <p class="text-[13px] leading-[1.65] text-text-secondary">
                {item.answer}
              </p>
            </section>
          ))
        }
      </div>
    </section>
  </div>
</section>
