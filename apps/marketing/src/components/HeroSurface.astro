---
import type { HeroSurfaceCopy } from '../i18n/types'
import KbdHint from './primitives/KbdHint.astro'

interface Props {
  t: HeroSurfaceCopy
}

const { t } = Astro.props

const rowTint: Record<'critical' | 'high' | 'medium', string> = {
  critical: 'bg-components-badge-bg-red-soft hover:bg-components-badge-bg-red-soft',
  high: 'bg-components-badge-bg-warning-soft hover:bg-components-badge-bg-warning-soft',
  medium: 'bg-components-badge-bg-gray-soft hover:bg-components-badge-bg-gray-soft',
}

const badgeBase =
  'inline-flex h-5 w-fit shrink-0 items-center justify-center gap-1 overflow-hidden rounded-full border border-transparent px-2 py-0.5 text-badge font-medium whitespace-nowrap transition-colors'

const badgeTone = {
  destructive: 'bg-components-badge-bg-red-soft text-text-destructive',
  warning: 'bg-components-badge-bg-warning-soft text-text-warning',
  info: 'bg-components-badge-bg-blue-soft text-text-accent',
  success: 'bg-components-badge-bg-green-soft text-text-success',
  secondary: 'bg-components-badge-bg-gray-soft text-text-secondary',
  outline: 'border-divider-regular text-text-secondary',
}

const statusDot = {
  success: 'bg-components-badge-status-light-success-bg shadow-status-indicator-green',
  warning: 'bg-components-badge-status-light-warning-bg shadow-status-indicator-warning',
  error: 'bg-components-badge-status-light-error-bg shadow-status-indicator-red',
  normal: 'bg-components-badge-status-light-normal-bg shadow-status-indicator-blue',
  disabled: 'bg-components-badge-status-light-disabled-bg shadow-status-indicator-gray',
}

const severityDot: Record<'critical' | 'high' | 'medium', keyof typeof statusDot> = {
  critical: 'error',
  high: 'warning',
  medium: 'disabled',
}
---

<div class="relative overflow-hidden rounded-xl border border-components-card-border bg-components-card-bg shadow-overlay">
  <div class="flex h-10 items-center justify-between border-b border-divider-subtle px-3">
    <div class="flex min-w-0 items-center gap-3">
      <div class="flex shrink-0 items-center gap-1.5">
        <span class="block h-2 w-2 rounded-full bg-severity-critical/70"></span>
        <span class="block h-2 w-2 rounded-full bg-severity-medium/70"></span>
        <span class="block h-2 w-2 rounded-full bg-status-done/70"></span>
      </div>
      <div class="flex min-w-0 items-center gap-1.5 truncate font-mono text-xs text-text-tertiary">
        <span class="block h-2.5 w-2.5 shrink-0 rounded-sm bg-background-subtle"></span>
        <span>{t.breadcrumb.workbench}</span>
        <span>/</span>
        <span>{t.breadcrumb.dashboard}</span>
        <span>/</span>
        <span class="text-text-secondary">{t.breadcrumb.week}</span>
      </div>
    </div>
    <KbdHint keys="⌘K" label={t.kbdCommand} />
  </div>

  <div class="flex items-center gap-3 border-b border-divider-subtle bg-components-badge-bg-warning-soft px-4 py-2.5">
    <span class:list={[badgeBase, 'rounded-md bg-components-badge-bg-warning-soft text-text-warning']}>
      <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot.warning]}></span>
      {t.pulse.tag}
    </span>
    <p class="min-w-0 flex-1 truncate text-xs text-text-primary">{t.pulse.text}</p>
    <span class="hidden rounded border border-divider-regular bg-background-default px-2 py-0.5 font-mono text-2xs text-text-secondary sm:inline-flex">
      {t.pulse.source}
    </span>
    <span class="font-mono text-xs text-text-accent">{t.pulse.cta} →</span>
  </div>

  <div class="grid gap-0 border-b border-divider-subtle lg:grid-cols-[1fr_0.82fr]">
    <div class="border-b border-divider-subtle px-4 py-4 lg:border-b-0 lg:border-r lg:border-divider-subtle">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 font-mono text-xs tracking-[0.08em] text-text-tertiary">
          <span class="block h-1.5 w-1.5 rounded-full bg-severity-critical"></span>
          <span>{t.metric.eyebrow}</span>
        </div>
        <span class:list={[badgeBase, 'border-divider-regular bg-background-section font-mono text-text-secondary']}>
          {t.metric.range}
        </span>
      </div>
      <div class="mt-3 flex items-end justify-between gap-4">
        <div>
          <div class="font-mono tabular text-[42px] font-bold leading-none text-text-primary">
            {t.metric.value}
          </div>
          <div class:list={[badgeBase, 'mt-2 bg-components-badge-bg-red-soft font-mono text-text-destructive']}>
            {t.metric.delta}
          </div>
        </div>
      </div>
    </div>

    <div class="grid content-start gap-3 px-4 py-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <div class="text-xs font-semibold text-text-primary">{t.brief.title}</div>
          <div class="mt-0.5 font-mono text-xs text-text-tertiary">{t.brief.citation}</div>
        </div>
        <span class:list={[badgeBase, 'bg-state-accent-active-alt font-mono text-text-accent']}>
          {t.brief.status}
        </span>
      </div>
      <p class="text-[12px] leading-relaxed text-text-secondary">{t.brief.text}</p>
    </div>
  </div>

  <div class="grid grid-cols-4 gap-0 border-b border-divider-subtle">
    {t.metric.stats.map((stat) => (
      <div class="border-r border-divider-subtle px-4 py-3 last:border-r-0">
        <div class="font-mono text-2xs tracking-wider text-text-tertiary">{stat.label}</div>
        <div class="mt-0.5 font-mono tabular text-[18px] font-semibold text-text-primary">{stat.value}</div>
      </div>
    ))}
  </div>

  <div class="flex items-center justify-between border-b border-divider-subtle px-4 py-2.5">
    <div class="flex rounded-md border border-divider-regular bg-background-section p-0.5 font-mono text-xs">
      {t.triageTabs.map((tab, idx) => (
        <span class:list={['px-2 py-1', idx === 0 ? 'rounded-sm bg-background-default text-text-primary' : 'text-text-secondary']}>
          {tab.label} · {tab.count}
        </span>
      ))}
    </div>
    <span class="font-mono text-xs text-text-tertiary">{t.liveLabel}</span>
  </div>

  <div class="overflow-x-auto">
    <div class="min-w-[960px]">
      <div class="grid h-9 grid-cols-[1.1fr_1.8fr_0.75fr_1.35fr_1.25fr_1.05fr_1fr_1.2fr] items-center gap-3 border-b border-divider-regular px-4 text-xs font-medium tracking-wider text-text-tertiary uppercase">
        <span class="-mx-2 inline-flex h-7 max-w-32 items-center gap-1 rounded-md px-2">
          {t.table.headers.priority}
          <span aria-hidden class="text-text-quaternary">↕</span>
        </span>
        <span class="-mx-2 inline-flex h-7 max-w-40 items-center gap-1 rounded-md px-2">
          {t.table.headers.client}
          <span aria-hidden class="text-text-quaternary">⌄</span>
        </span>
        <span>{t.table.headers.form}</span>
        <span class="-mx-2 inline-flex h-7 max-w-36 items-center gap-1 rounded-md px-2">
          {t.table.headers.due}
          <span aria-hidden class="text-text-quaternary">↕</span>
        </span>
        <span class="-mx-2 inline-flex h-7 max-w-36 items-center gap-1 rounded-md px-2">
          {t.table.headers.status}
          <span aria-hidden class="text-text-quaternary">⌄</span>
        </span>
        <span>{t.table.headers.severity}</span>
        <span class="-mx-2 inline-flex h-7 max-w-36 items-center justify-end gap-1 rounded-md px-2 text-right">
          {t.table.headers.exposure}
          <span aria-hidden class="text-text-quaternary">↕</span>
        </span>
        <span>{t.table.headers.evidence}</span>
      </div>
      {t.table.rows.slice(0, 4).map((row) => (
        <div class:list={['grid h-9 grid-cols-[1.1fr_1.8fr_0.75fr_1.35fr_1.25fr_1.05fr_1fr_1.2fr] items-center gap-3 border-b border-divider-subtle px-4 text-xs transition-colors last:border-b-0', rowTint[row.severity]]}>
          <span class:list={[badgeBase, badgeTone[row.priorityTone], 'font-mono tabular-nums']}>
            {row.priorityScore}
            {row.priorityRank && <span>{row.priorityRank}</span>}
          </span>
          <div class="flex min-w-0 items-center gap-3">
            <div class="min-w-0 leading-tight">
              <div class="truncate text-xs font-medium text-text-primary">{row.client}</div>
              <div class="font-mono text-xs text-text-tertiary">{row.ein}</div>
            </div>
          </div>
          <span class="font-mono text-xs text-text-secondary">{row.form}</span>
          <span class="flex min-w-0 items-center gap-2 font-mono text-xs tabular-nums text-text-secondary">
            <span class:list={[badgeBase, badgeTone[row.severity === 'medium' ? 'outline' : 'warning'], 'min-w-16 justify-start font-mono']}>
              {row.daysLeft}
            </span>
            <span>{row.due}</span>
          </span>
          <span class:list={[badgeBase, badgeTone[row.statusTone]]}>
            <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[row.statusDotTone]]}></span>
            {row.status}
          </span>
          <span class:list={[badgeBase, badgeTone[row.severity === 'critical' ? 'destructive' : row.severity === 'high' ? 'warning' : 'secondary'], 'uppercase tracking-wide']}>
            <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[severityDot[row.severity]]]}></span>
            {row.severityLabel}
          </span>
          <span class:list={[badgeBase, badgeTone[row.exposureTone], 'ml-auto font-mono tabular-nums']}>{row.exposure}</span>
          <span class:list={[badgeBase, badgeTone[row.evidenceTone], 'font-mono']}>
            <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot.normal]}></span>
            {row.evidence}
          </span>
        </div>
      ))}
    </div>
  </div>

  <div class="flex items-center gap-4 border-t border-divider-subtle px-4 py-2.5">
    {t.hints.slice(0, 3).map((hint) => (
      <KbdHint keys={hint.keys} label={hint.label} variant="inline" />
    ))}
  </div>
</div>
