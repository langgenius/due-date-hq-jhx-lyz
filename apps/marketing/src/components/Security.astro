---
import type { SecurityCopy } from '../i18n/types'

interface Props {
  t: SecurityCopy
}

const { t } = Astro.props
---

<section id="security" class="border-b border-border-default bg-bg-canvas">
  <div class="mx-auto flex max-w-[1440px] flex-wrap items-center gap-x-10 gap-y-3 px-20 py-10">
    <span class="font-mono text-[12px] tracking-[0.18em] text-text-muted">{t.title}</span>
    <div class="flex flex-1 flex-wrap items-center gap-x-8 gap-y-3">
      {t.items.map((item) => (
        <span class="inline-flex items-center gap-2 text-[13px]">
          <span class="block h-1.5 w-1.5 rounded-full bg-status-done"></span>
          <span class="font-medium text-text-primary">{item.pill}</span>
          <span class="text-text-secondary">{item.body}</span>
        </span>
      ))}
    </div>
  </div>
</section>
