# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  apps/server/.dev.vars  (copy from this file; gitignored)                ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║  Scope · This file is read by `wrangler dev` ONLY, and injected into     ║
# ║  the Worker's `env` object at runtime. Cloudflare bindings (D1, KV, R2,  ║
# ║  Vectorize, Queues, Assets) are declared in wrangler.toml, not here —    ║
# ║  this file is reserved for RUNTIME SECRETS and per-env config.           ║
# ║                                                                          ║
# ║  ⚠ NOT read in staging/production. Use `wrangler secret put <NAME>`      ║
# ║    (or Cloudflare Dashboard → Worker → Settings → Variables).            ║
# ║                                                                          ║
# ║  ⚠ NOT the place for CLI credentials (CLOUDFLARE_ACCOUNT_ID,             ║
# ║    CLOUDFLARE_API_TOKEN, NODE_ENV). Those live in root `.env`.           ║
# ║                                                                          ║
# ║  ⚠ NOT the place for browser-facing vars. Those go to                    ║
# ║    apps/app/.env.local with a `VITE_` prefix.                            ║
# ║                                                                          ║
# ║  Schema validated by apps/server/src/env.ts (`validateServerEnv`).       ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ═════════════════════════════════════════════════════════════════════════════
# [Required] App · environment + URLs
# ═════════════════════════════════════════════════════════════════════════════
# ENV       · development | staging | production
# AUTH_URL  · origin of THIS Worker (where /api/auth/* is served)
# APP_URL   · origin of the browser-facing SPA; used for
#              (a) Better Auth trustedOrigins whitelist
#              (b) absolute links inside outbound emails
#             In dev the SPA runs on Vite (5173); in prod it's the Worker itself.
ENV=development
AUTH_URL=http://localhost:8787
APP_URL=http://localhost:5173

# ═════════════════════════════════════════════════════════════════════════════
# [Required] Better Auth · session secret + Google OAuth provider
# ═════════════════════════════════════════════════════════════════════════════
# AUTH_SECRET · `openssl rand -base64 32`   (min 32 chars — validated by Zod)
# Google Console → Credentials → OAuth 2.0 Client IDs
#   Redirect URI must include: {AUTH_URL}/api/auth/callback/google
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional Microsoft Entra ID OAuth for Outlook / Microsoft 365 firms.
# Azure Portal → App registrations → Authentication
# Redirect URI must include: {AUTH_URL}/api/auth/oauth2/callback/microsoft-entra-id
# MICROSOFT_TENANT_ID may be "common" for multi-tenant sign-in.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ═════════════════════════════════════════════════════════════════════════════
# [Optional until email send] Mail · Resend
# ═════════════════════════════════════════════════════════════════════════════
# RESEND_API_KEY may be blank for login + organization bootstrap. Auth email
# sending still requires it outside development; development prints to console.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=noreply@duedatehq.com

# ═════════════════════════════════════════════════════════════════════════════
# [Optional until Pulse ops review] Internal ops · Pulse review API
# ═════════════════════════════════════════════════════════════════════════════
# Protects /api/ops/pulse/* with Authorization: Bearer <token>. Use a random
# value (`openssl rand -base64 32`) when running the ops review scripts.
PULSE_OPS_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional until billing test] Stripe · Better Auth subscription checkout
# ═════════════════════════════════════════════════════════════════════════════
# Local webhook test:
#   stripe listen --forward-to localhost:8787/api/auth/stripe/webhook
# Then copy the printed whsec_* value into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Required for self-serve Pro checkout.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Optional for sales-assisted Firm subscriptions.
STRIPE_PRICE_FIRM_MONTHLY=
STRIPE_PRICE_FIRM_YEARLY=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional] AI SDK via Cloudflare AI Gateway
# ═════════════════════════════════════════════════════════════════════════════
# Default local/staging path uses Cloudflare AI Gateway Provider Native for
# OpenRouter:
#   DueDateHQ → Cloudflare AI Gateway ({account}/{slug}) → OpenRouter.
#
# Fill AI_GATEWAY_PROVIDER_API_KEY with your OpenRouter token. This is the only
# required secret for the OpenRouter path. Do not put an OpenAI key here.
#
# AI_GATEWAY_MODEL is the OpenRouter model id to request through the gateway.
# Examples: openai/gpt-5-mini, anthropic/claude-sonnet-4.5, google/gemini-2.5-pro
#
# Leave AI_GATEWAY_API_KEY empty unless you explicitly enable Cloudflare
# Authenticated Gateway or switch AI_GATEWAY_PROVIDER away from openrouter.
AI_GATEWAY_ACCOUNT_ID=
AI_GATEWAY_SLUG=duedatehq
AI_GATEWAY_PROVIDER=openrouter
AI_GATEWAY_PROVIDER_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-mini
AI_GATEWAY_API_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional · Phase 1+] Web Push
# ═════════════════════════════════════════════════════════════════════════════
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@duedatehq.com

# ═════════════════════════════════════════════════════════════════════════════
# [Optional] Observability
# ═════════════════════════════════════════════════════════════════════════════
SENTRY_DSN=
POSTHOG_KEY=
